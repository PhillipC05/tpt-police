  PROFESSIONAL
  ENTERPRISE
  GOVERNMENT
}

enum BillingCycle {
  MONTHLY
  ANNUAL
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
}

model Subscription {
  id            String             @id @default(cuid())
  tenantId      String             @unique
