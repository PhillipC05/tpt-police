generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum TenantType {
  NATION
  PROVINCE
  CITY
  PRECINCT
}

enum UserRole {
  SUPER_ADMIN
  PROVINCE_ADMIN
  CITY_ADMIN
  PRECINCT_ADMIN
  DETECTIVE
  OFFICER
  DISPATCHER
  PUBLIC
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  ON_LEAVE
}

enum SeverityLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum DisciplinaryStatus {
  INVESTIGATING
  SUBSTANTIATED
  DISMISSED
  ACTION_TAKEN
}

enum TrainingStatus {
  ACTIVE
  EXPIRED
  REVOKED
}

enum ExpenseStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  REIMBURSED
}

enum PayrollStatus {
  PENDING
  PROCESSED
  PAID
  CANCELLED
}

enum ShiftSwapStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CaseStatus {
  OPEN
  ACTIVE
  REVIEW
  PROSECUTION
  CLOSED
}

enum CaseType {
  THEFT
  ASSAULT
  HOMICIDE
  FRAUD
  DRUG_OFFENCE
  CYBERCRIME
  DOMESTIC_VIOLENCE
  MISSING_PERSON
  TRAFFIC
  PUBLIC_ORDER
  OTHER
}

enum EvidenceType {
  PHYSICAL
  DIGITAL
  DOCUMENTARY
  BIOLOGICAL
  AUDIO
  VIDEO
  PHOTO
}

enum PersonRole {
  SUSPECT
  WITNESS
  VICTIM
  PERSON_OF_INTEREST
}

enum AssetStatus {
  AVAILABLE
  ISSUED
  MAINTENANCE
  DECOMMISSIONED
  LOST
}

enum VehicleStatus {
  AVAILABLE
  ASSIGNED
  MAINTENANCE
  DECOMMISSIONED
}

enum ShiftType {
  MORNING
  AFTERNOON
  NIGHT
  CUSTOM
}

enum LeaveType {
  ANNUAL
  SICK
  MATERNITY
  PATERNITY
  STUDY
  SPECIAL
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum PurchaseOrderStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  COMPLETED
}

enum FoiaStatus {
  SUBMITTED
  UNDER_REVIEW
  INFORMATION_REQUESTED
  COMPLETED
  DENIED
}

enum HandoffStatus {
  PREPARING
  SUBMITTED
  ACCEPTED
  COURT_DATE_SET
  CONCLUDED
}

enum IncidentStatus {
  ACTIVE
  RESOLVED
  CANCELLED
}

// ─── Phase 11 enums ────────────────────────────

enum WarrantType {
  ARREST
  SEARCH
  PROTECTION
}

enum WarrantStatus {
  ISSUED
  SERVED
  RETURNED
  EXPIRED
}

enum ForceType {
  VERBAL
  PHYSICAL
  RESTRAINT
  CEW
  FIREARM
  OTHER
}

enum UseOfForceStatus {
  SUBMITTED
  UNDER_REVIEW
  REVIEWED
  ESCALATED
}

enum BookingStatus {
  BOOKED
  BAILED
  RELEASED
  TRANSFERRED
  CHARGED
}

enum AlertType {
  BOLO
  APB
  AMBER_ALERT
  SILVER_ALERT
}

enum AlertStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum FieldContactType {
  TRAFFIC_STOP
  FIELD_INTERVIEW
  PEDESTRIAN_STOP
  WARRANT_CHECK
}

enum GangType {
  STREET_GANG
  ORGANIZED_CRIME
  EXTREMIST
  CARTEL
  MOTORCYCLE_CLUB
  OTHER
}

enum GangStatus {
  ACTIVE
  INACTIVE
  DISBANDED
}

enum GangMemberRole {
  LEADER
  LIEUTENANT
  MEMBER
  ASSOCIATE
  SUSPECTED
}

enum AssociationType {
  KNOWN_ASSOCIATE
  FAMILY
  EMPLOYER
  BUSINESS_PARTNER
  RIVAL
  CO_DEFENDANT
  INFORMANT
}

enum ConfidenceLevel {
  CONFIRMED
  SUSPECTED
  UNVERIFIED
}

enum ThreatLevel {
  NONE
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum CameraSourceType {
  BWC
  SMART_GLASSES
  CCTV
  DRONE
}

enum CameraDeviceType {
  BWC
  SMART_GLASSES
}

enum DroneCategory {
  AERIAL
  GROUND
}

enum SurveillanceCameraStatus {
  ONLINE
  OFFLINE
  MAINTENANCE
}

// ─────────────────────────────────────────────
// MULTI-TENANCY
// ─────────────────────────────────────────────

model Tenant {
  id        String     @id @default(cuid())
  name      String
  type      TenantType
  parentId  String?
  parent    Tenant?    @relation("TenantHierarchy", fields: [parentId], references: [id])
  children  Tenant[]   @relation("TenantHierarchy")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  users            User[]
  cases            Case[]
  assets           Asset[]
  vehicles         Vehicle[]
  shifts           Shift[]
  shiftTemplates   ShiftTemplate[]
  budgets          Budget[]
  foiaRequests     FoiaRequest[]
  incidents        Incident[]
  officerLocations OfficerLocation[]
  leaveRequests    LeaveRequest[]
  purchaseOrders   PurchaseOrder[]
  disciplinaryIncidents DisciplinaryIncident[]
  trainingCertificates  TrainingCertification[]
  payrollPeriods   PayrollPeriod[]
  expenseClaims    ExpenseClaim[]
  subscription     Subscription?
  dataRetentionPolicy DataRetentionPolicy?
  crimeMapPrivacySetting CrimeMapPrivacySetting?
  scheduledReports   ScheduledReport[]
  warrants           Warrant[]
  useOfForce         UseOfForce[]
  bookings           Booking[]
  alerts             Alert[]
  fieldContacts      FieldContact[]
  storageLocations   StorageLocation[]
  foundProperties    FoundProperty[]
  labSubmissions     LabSubmission[]
  civilianComplaints CivilianComplaint[]
  courtAppearances   CourtAppearance[]
  panicEvents        PanicEvent[]
  neighbourhoodWatch NeighbourhoodWatch[]
  communityEvents    CommunityEvent[]
  officerCommendations OfficerCommendation[]
  patrolZones        PatrolZone[]
  drones             Drone[]
  publicPortalConfig PublicPortalConfig?
  publicSubmissions  PublicSubmission[]
  gangs              Gang[]
  personAssociations PersonAssociation[]
  scanConfig         ScanConfig?
  surveillanceCameras SurveillanceCamera[]
  faceScanSessions   FaceScanSession[]
  facialMatches      FacialMatch[]

  @@index([parentId])
  @@index([type])
}

// ─────────────────────────────────────────────
// AUTH & USERS
// ─────────────────────────────────────────────

model User {
  id            String     @id @default(cuid())
  tenantId      String
  tenant        Tenant     @relation(fields: [tenantId], references: [id])
  role          UserRole   @default(OFFICER)
  status        UserStatus @default(ACTIVE)
  name          String
  email         String     @unique
  emailVerified DateTime?
  passwordHash  String?
  badgeNumber   String?
  rank          String?
  department    String?
  phone         String?
  photoUrl      String?
  mfaSecret     String?
  mfaEnabled    Boolean    @default(false)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  accounts      Account[]
  sessions      Session[]
  assignedCases CaseAssignment[]
  evidenceLog   EvidenceCustody[]
  auditLogs     AuditLog[]
  shifts        ShiftAssignment[]
  leaveRequests LeaveRequest[]
  issuedAssets  AssetIssuance[]
  assignedVehicles VehicleAssignment[]
  tipsSubmitted CrimeTip[]
  notes         CaseNote[]
  performanceReviews PerformanceReview[]
  disciplinaryIncidents DisciplinaryIncident[]
  trainingCertifications TrainingCertification[]
  payrollEntries   PayrollEntry[]
  expenseClaims    ExpenseClaim[]
  shiftSwapRequests ShiftSwap[] @relation("ShiftSwapRequestor")
  shiftSwapTargets  ShiftSwap[] @relation("ShiftSwapTarget")
  officerLocation   OfficerLocation?
  scheduledReports  ScheduledReport[]
  warrantsIssued       Warrant[]    @relation("WarrantIssuedBy")
  warrantsServed       Warrant[]    @relation("WarrantServedBy")
  uofReports           UseOfForce[] @relation("UofFOfficer")
  uofSupervisedReports UseOfForce[] @relation("UofFSupervisor")
  bookingsMade         Booking[]    @relation("BookingOfficer")
  alertsIssued         Alert[]      @relation("AlertIssuedBy")
  fieldContacts        FieldContact[] @relation("FieldContactOfficer")
  assignedCameras      BodyCamera[]   @relation("CameraAssignment")
  bwcEvents            BWCEvent[]
  complaintSubject     CivilianComplaint[] @relation("ComplaintSubjectOfficer")
  complaintReviewer    CivilianComplaint[] @relation("ComplaintReviewer")
  courtAppearances     CourtAppearance[]
  panicEvents          PanicEvent[]
  wellnessCheckins     WellnessCheckin[]
  counsellingSessions  CounsellingSession[]
  commendationsReceived OfficerCommendation[]
  droneOperations      DroneDeployment[]
  publicProfile        PublicProfile?
  pushSubscriptions    PushSubscription[]
  faceScanSessions     FaceScanSession[]  @relation("FaceScanOfficer")
  facialMatchAlerts    FacialMatch[]      @relation("FacialMatchAlert")

  @@index([tenantId])
  @@index([email])
  @@index([badgeNumber])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────
// AUDIT LOGGING
// ─────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  tenantId   String
  action     String
  resource   String
  resourceId String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([tenantId])
  @@index([userId])
  @@index([resource, resourceId])
  @@index([createdAt])
}

// ─────────────────────────────────────────────
// CASE MANAGEMENT
// ─────────────────────────────────────────────

model Case {
  id          String     @id @default(cuid())
  caseNumber  String     @unique
  tenantId    String
  tenant      Tenant     @relation(fields: [tenantId], references: [id])
  type        CaseType
  status      CaseStatus @default(OPEN)
  title       String
  description String     @db.Text
  incidentDate DateTime?
  location    String?
  latitude    Float?
  longitude   Float?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  closedAt    DateTime?

  assignments    CaseAssignment[]
  evidence       Evidence[]
  persons        CasePersonLink[]
  notes          CaseNote[]
  sharedWith     CaseShare[]
  handoff        CourtHandoff?
  linkedIncident Incident?        @relation(fields: [linkedIncidentId], references: [id])
  linkedIncidentId String?
  warrants       Warrant[]
  useOfForce     UseOfForce[]
  bookings       Booking[]
  dispositions   EvidenceDisposition[]
  courtAppearances CourtAppearance[]

  @@index([tenantId])
  @@index([status])
  @@index([caseNumber])
}

model CaseAssignment {
  id         String   @id @default(cuid())
  caseId     String
  case       Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  assignedAt DateTime @default(now())
  isLead     Boolean  @default(false)

  @@unique([caseId, userId])
}

model CaseNote {
  id        String   @id @default(cuid())
  caseId    String
  case      Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([caseId])
}

model CaseShare {
  id               String   @id @default(cuid())
  caseId           String
  case             Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  sharedWithTenantId String
  canEdit          Boolean  @default(false)
  isJointInvestigation Boolean @default(false)
  approvedAt       DateTime?
  requestedById    String?
  createdAt        DateTime @default(now())

  @@unique([caseId, sharedWithTenantId])
}

// ─────────────────────────────────────────────
// EVIDENCE
// ─────────────────────────────────────────────

model Evidence {
  id           String       @id @default(cuid())
  caseId       String
  case         Case         @relation(fields: [caseId], references: [id], onDelete: Cascade)
  type         EvidenceType
  description  String
  storageLocation String?
  fileUrl      String?
  fileKey      String?
  fileSize     Int?
  mimeType     String?
  tagNumber    String?
  collectedAt  DateTime?
  collectedBy  String?
  createdAt    DateTime     @default(now())

  custodyChain EvidenceCustody[]
  disposition   EvidenceDisposition?
  controlledSubstance ControlledSubstance?
  labSubmissions LabSubmission[]

  @@index([caseId])
}

model EvidenceCustody {
  id          String   @id @default(cuid())
  evidenceId  String
  evidence    Evidence @relation(fields: [evidenceId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  action      String
  reason      String?
  location    String?
  createdAt   DateTime @default(now())

  @@index([evidenceId])
}

// ─────────────────────────────────────────────
// PERSONS (Suspects, Witnesses, Victims)
// ─────────────────────────────────────────────

model Person {
  id          String      @id @default(cuid())
  firstName   String
  lastName    String
  dateOfBirth DateTime?
  idNumber    String?
  nationality String?
  gender      String?
  phone       String?
  email       String?
  address     String?
  photoUrl    String?
  notes       String?     @db.Text
  threatLevel ThreatLevel @default(NONE)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  caseLinks       CasePersonLink[]
  statements      Statement[]
  warrants        Warrant[]
  bookings        Booking[]
  alerts          Alert[]
  fieldContacts   FieldContact[]
  gangMemberships GangMember[]
  associationsA   PersonAssociation[] @relation("AssocA")
  associationsB   PersonAssociation[] @relation("AssocB")
  facialMatches   FacialMatch[]

  @@index([idNumber])
  @@index([threatLevel])
}

model CasePersonLink {
  id         String     @id @default(cuid())
  caseId     String
  case       Case       @relation(fields: [caseId], references: [id], onDelete: Cascade)
  personId   String
  person     Person     @relation(fields: [personId], references: [id])
  role       PersonRole
  createdAt  DateTime   @default(now())

  @@unique([caseId, personId, role])
}

model Statement {
  id          String   @id @default(cuid())
  personId    String
  person      Person   @relation(fields: [personId], references: [id])
  content     String   @db.Text
  fileUrl     String?
  takenAt     DateTime @default(now())
  takenById   String?
}

// ─────────────────────────────────────────────
// INTELLIGENCE (Gangs, Networks, POI)
// ─────────────────────────────────────────────

model Gang {
  id          String     @id @default(cuid())
  name        String
  aliases     String[]
  type        GangType
  status      GangStatus @default(ACTIVE)
  territory   String?    @db.Text
  description String?    @db.Text
  tenantId    String
  tenant      Tenant     @relation(fields: [tenantId], references: [id])
  createdById String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  members     GangMember[]

  @@index([tenantId])
  @@index([name])
}

model GangMember {
  id        String         @id @default(cuid())
  gangId    String
  gang      Gang           @relation(fields: [gangId], references: [id], onDelete: Cascade)
  personId  String
  person    Person         @relation(fields: [personId], references: [id])
  role      GangMemberRole @default(MEMBER)
  joinedAt  DateTime?
  leftAt    DateTime?
  notes     String?        @db.Text
  createdAt DateTime       @default(now())

  @@unique([gangId, personId])
  @@index([personId])
}

model PersonAssociation {
  id               String          @id @default(cuid())
  personAId        String
  personA          Person          @relation("AssocA", fields: [personAId], references: [id])
  personBId        String
  personB          Person          @relation("AssocB", fields: [personBId], references: [id])
  relationshipType AssociationType
  confidence       ConfidenceLevel @default(UNVERIFIED)
  notes            String?         @db.Text
  tenantId         String
  tenant           Tenant          @relation(fields: [tenantId], references: [id])
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@unique([personAId, personBId, relationshipType])
  @@index([tenantId])
  @@index([personAId])
  @@index([personBId])
}

// ─────────────────────────────────────────────
// COURT HANDOFF
// ─────────────────────────────────────────────

model CourtHandoff {
  id                   String        @id @default(cuid())
  caseId               String        @unique
  case                 Case          @relation(fields: [caseId], references: [id])
  status               HandoffStatus @default(PREPARING)
  prosecutorName       String?
  prosecutorRef        String?
  submittedAt          DateTime?
  courtDate            DateTime?
  courtName            String?
  notes                String?       @db.Text
  packageFileUrl       String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
}

// ─────────────────────────────────────────────
// DISPATCH INTEGRATION
// ─────────────────────────────────────────────

model OfficerLocation {
  id         String   @id @default(cuid())
  officerId  String
  officer    User     @relation(fields: [officerId], references: [id])
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  latitude   Float
  longitude  Float
  heading    Float?
  speed      Float?
  accuracy   Float?
  status     String   @default("ON_DUTY")
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())

  @@index([officerId])
  @@index([tenantId])
  @@index([updatedAt])
  @@unique([officerId])
}

model Incident {
  id             String         @id @default(cuid())
  tenantId       String
  tenant         Tenant         @relation(fields: [tenantId], references: [id])
  externalId     String?        @unique
  type           String
  status         IncidentStatus @default(ACTIVE)
  description    String?        @db.Text
  location       String?
  latitude       Float?
  longitude      Float?
  reportedAt     DateTime       @default(now())
  resolvedAt     DateTime?
  rawPayload     Json?

  linkedCases    Case[]
  useOfForce     UseOfForce[]
  droneDeployments DroneDeployment[]

  @@index([tenantId])
  @@index([status])
}

// ─────────────────────────────────────────────
// HR — STAFF & LEAVE
// ─────────────────────────────────────────────

model LeaveRequest {
  id          String      @id @default(cuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id])
  tenantId    String
  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  type        LeaveType
  status      LeaveStatus @default(PENDING)
  startDate   DateTime
  endDate     DateTime
  reason      String?     @db.Text
  approvedById String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([userId])
  @@index([tenantId])
}

model PerformanceReview {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  reviewedById String
  rating      Int
  period      String
  notes       String?  @db.Text
  createdAt   DateTime @default(now())

  @@index([userId])
}

// ─────────────────────────────────────────────
// HR — DISCIPLINARY & TRAINING
// ─────────────────────────────────────────────

model DisciplinaryIncident {
  id            String             @id @default(cuid())
  userId        String
  user          User               @relation(fields: [userId], references: [id])
  tenantId      String
  tenant        Tenant             @relation(fields: [tenantId], references: [id])
  incident      String
  date          DateTime
  severity      SeverityLevel
  description   String             @db.Text
  actionTaken   String?
  status        DisciplinaryStatus @default(INVESTIGATING)
  createdById   String
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([userId])
  @@index([tenantId])
}

model TrainingCertification {
  id            String        @id @default(cuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id])
  tenantId      String
  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  name          String
  issuingBody   String
  certificateNo String?
  issuedAt      DateTime
  expiresAt     DateTime?
  status        TrainingStatus @default(ACTIVE)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([userId])
  @@index([tenantId])
  @@index([expiresAt])
}

// ─────────────────────────────────────────────
// SHIFT SCHEDULING
// ─────────────────────────────────────────────

model ShiftTemplate {
  id        String    @id @default(cuid())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  name      String
  type      ShiftType
  startTime DateTime
  endTime   DateTime
  dayOfWeek Int?      // 0=Sunday, 6=Saturday, null=recurring
  createdAt DateTime  @default(now())

  @@index([tenantId])
}

model Shift {
  id        String    @id @default(cuid())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  name      String
  type      ShiftType
  startTime DateTime
  endTime   DateTime
  createdAt DateTime  @default(now())

  assignments ShiftAssignment[]
  swapRequests ShiftSwap[]

  @@index([tenantId])
}

model ShiftAssignment {
  id         String   @id @default(cuid())
  shiftId    String
  shift      Shift    @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  isOvertime Boolean  @default(false)
  notes      String?
  createdAt  DateTime @default(now())

  @@unique([shiftId, userId])
}

model ShiftSwap {
  id               String          @id @default(cuid())
  shiftId          String
  shift            Shift           @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  requestingUserId String
  requestingUser   User            @relation("ShiftSwapRequestor", fields: [requestingUserId], references: [id])
  targetUserId     String
  targetUser       User            @relation("ShiftSwapTarget", fields: [targetUserId], references: [id])
  reason           String?         @db.Text
  status           ShiftSwapStatus @default(PENDING)
  approvedById     String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([shiftId])
  @@index([requestingUserId])
}

// ─────────────────────────────────────────────
// PAYROLL
// ─────────────────────────────────────────────

model PayrollPeriod {
  id            String        @id @default(cuid())
  tenantId      String
  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  name          String
  startDate     DateTime
  endDate       DateTime
  status        PayrollStatus @default(PENDING)
  processedAt   DateTime?
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  entries PayrollEntry[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model PayrollEntry {
  id              String        @id @default(cuid())
  payrollPeriodId String
  payrollPeriod   PayrollPeriod @relation(fields: [payrollPeriodId], references: [id], onDelete: Cascade)
  userId          String
  user            User          @relation(fields: [userId], references: [id])
  baseHours       Float         @default(0)
  overtimeHours   Float         @default(0)
  overtimeRate    Float         @default(1.5)
  allowances      Float         @default(0)
  deductions      Float         @default(0)
  grossPay        Float         @default(0)
  netPay          Float         @default(0)
  status          PayrollStatus @default(PENDING)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([payrollPeriodId])
