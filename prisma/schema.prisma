}

// ─────────────────────────────────────────────
// PHASE 13 — DRONE FLEET MANAGEMENT
// ─────────────────────────────────────────────

enum DroneStatus {
  AVAILABLE
  DEPLOYED
  CHARGING
  MAINTENANCE
  DECOMMISSIONED
}

model Drone {
  id                  String        @id @default(cuid())
  tenantId            String
  tenant              Tenant        @relation(fields: [tenantId], references: [id])
  serialNumber        String        @unique
  model               String
  category            DroneCategory @default(AERIAL)
  status              DroneStatus   @default(AVAILABLE)
  batteryPercent      Int           @default(100)
  lastServiceAt       DateTime?
  certificationExpiry DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  deployments       DroneDeployment[]

  @@index([tenantId])
  @@index([status])
}

model DroneDeployment {
  id              String   @id @default(cuid())
  droneId         String
  drone           Drone    @relation(fields: [droneId], references: [id])
  operatorId      String
  operator        User     @relation(fields: [operatorId], references: [id])
  incidentId      String?
  incident        Incident? @relation(fields: [incidentId], references: [id])
  launchedAt      DateTime
  landedAt        DateTime?
  footageUrl      String?
  notes           String?  @db.Text
  authorizedById  String?
  approved        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  faceScanSessions FaceScanSession[]

  @@index([droneId])
  @@index([operatorId])
}

// ─────────────────────────────────────────────
// PUBLIC PORTAL — Portal Configuration
// ─────────────────────────────────────────────

model PublicPortalConfig {
  id                    String   @id @default(cuid())
  tenantId              String   @unique
  tenant                Tenant   @relation(fields: [tenantId], references: [id])

  // Feature toggles (all default true)
  tipsEnabled           Boolean  @default(true)
  complaintsEnabled     Boolean  @default(true)
  commendationsEnabled  Boolean  @default(true)
  missingPersonReports  Boolean  @default(true)
  communityEventsPublic Boolean  @default(true)
  neighbourhoodWatch    Boolean  @default(true)
  liveAlerts            Boolean  @default(true)
  evidenceUploads       Boolean  @default(true)
  publicRegistration    Boolean  @default(true)

  // Branding
  portalName            String   @default("TPT Police — Community Portal")
  portalDescription     String?  @db.Text
  logoUrl               String?
  primaryColor          String   @default("#1e3a5f")
  contactEmail          String?
  contactPhone          String?

  // Location for proximity matching
  latitude              Float?
  longitude             Float?
  serviceAreaRadiusKm   Float    @default(50)

  updatedAt             DateTime @updatedAt
  createdAt             DateTime @default(now())

  @@index([tenantId])
}

// ─────────────────────────────────────────────
// PUBLIC PORTAL — Citizen Profile
// ─────────────────────────────────────────────

model PublicProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName   String?
  phone         String?
  avatarUrl     String?
  emailVerified Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  submissions   PublicSubmission[]
}

// ─────────────────────────────────────────────
// PUBLIC PORTAL — Unified Submission Tracker
// ─────────────────────────────────────────────

model PublicSubmission {
  id              String   @id @default(cuid())
  referenceNumber String   @unique
  citizenId       String?
  citizen         PublicProfile? @relation(fields: [citizenId], references: [id])
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  type            String   // TIP | COMPLAINT | COMMENDATION | MISSING_PERSON | FOIA | EVIDENCE
  status          String   @default("SUBMITTED")
  description     String   @db.Text
  location        String?
  latitude        Float?
  longitude       Float?
  isAnonymous     Boolean  @default(true)
  // For linking to the underlying record after processing
  linkedRecordType String?
  linkedRecordId   String?
  // Admin notes
  publicResponse  String?  @db.Text
  internalNotes   String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  attachments     SubmissionAttachment[]
  statusHistory   SubmissionStatusHistory[]

  @@index([tenantId])
  @@index([citizenId])
  @@index([referenceNumber])
  @@index([type])
}

model SubmissionAttachment {
  id             String   @id @default(cuid())
  submissionId   String
  submission     PublicSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  fileName       String
  fileKey        String
  mimeType       String
  fileSize       Int
  uploadedAt     DateTime @default(now())

  @@index([submissionId])
}

model SubmissionStatusHistory {
  id           String   @id @default(cuid())
  submissionId String
  submission   PublicSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  fromStatus   String?
  toStatus     String
  changedById  String?
  note         String?  @db.Text
  createdAt    DateTime @default(now())

  @@index([submissionId])
}

// ─────────────────────────────────────────────
// PHASE 11 END MODELS (FieldContact)
// ─────────────────────────────────────────────

model FieldContact {
  id              String           @id @default(cuid())
  tenantId        String
  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  officerId       String
  officer         User             @relation("FieldContactOfficer", fields: [officerId], references: [id])
  contactType     FieldContactType
  contactDate     DateTime
  location        String?
  latitude        Float?
  longitude       Float?
  subjectName     String?
  subjectDob      String?
  subjectIdNumber String?
  vehiclePlate    String?
  vehicleMake     String?
  vehicleModel    String?
  personId        String?
  person          Person?          @relation(fields: [personId], references: [id])
  outcome         String?
  notes           String?          @db.Text
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([tenantId])
  @@index([officerId])
  @@index([personId])
}

// ─────────────────────────────────────────────
// PWA — Push Subscriptions
// ─────────────────────────────────────────────

// ─────────────────────────────────────────────
// FACIAL RECOGNITION / IDENTITY SCANNER
// ─────────────────────────────────────────────

model ScanConfig {
  id                 String      @id @default(cuid())
  tenantId           String      @unique
  tenant             Tenant      @relation(fields: [tenantId], references: [id])
  masterEnabled      Boolean     @default(false)
  scanMissingPersons Boolean     @default(true)
  scanActiveWarrants Boolean     @default(false)
  scanGangMembers    Boolean     @default(false)
  minThreatLevelScan ThreatLevel @default(NONE)
  minConfidence      Int         @default(85)
  requiresApproval   Boolean     @default(false)
  updatedById        String?
  updatedAt          DateTime    @updatedAt
  createdAt          DateTime    @default(now())
}

model SurveillanceCamera {
  id          String                   @id @default(cuid())
  name        String
  location    String?
  latitude    Float?
  longitude   Float?
  streamUrl   String?
  status      SurveillanceCameraStatus @default(ONLINE)
  scanEnabled Boolean                  @default(true)
  tenantId    String
  tenant      Tenant                   @relation(fields: [tenantId], references: [id])
  installedAt DateTime?
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  sessions    FaceScanSession[]

  @@index([tenantId])
}

model FaceScanSession {
  id                String              @id @default(cuid())
  sourceType        CameraSourceType
  bwcCameraId       String?
  bwcCamera         BodyCamera?         @relation(fields: [bwcCameraId], references: [id])
  droneDeploymentId String?
  droneDeployment   DroneDeployment?    @relation(fields: [droneDeploymentId], references: [id])
  surveillanceCamId String?
  surveillanceCam   SurveillanceCamera? @relation(fields: [surveillanceCamId], references: [id])
  officerId         String?
  officer           User?               @relation("FaceScanOfficer", fields: [officerId], references: [id])
  tenantId          String
  tenant            Tenant              @relation(fields: [tenantId], references: [id])
  startedAt         DateTime            @default(now())
  endedAt           DateTime?
  frameCount        Int                 @default(0)
  matchCount        Int                 @default(0)
  configSnapshot    Json

  matches           FacialMatch[]

  @@index([tenantId])
  @@index([officerId])
}

model FacialMatch {
  id            String          @id @default(cuid())
  personId      String
  person        Person          @relation(fields: [personId], references: [id])
  sessionId     String
  session       FaceScanSession @relation(fields: [sessionId], references: [id])
  confidence    Float
  matchReasons  String[]
  thumbnailUrl  String?
  alertedUserId String?
  alertedUser   User?           @relation("FacialMatchAlert", fields: [alertedUserId], references: [id])
  alertedAt     DateTime?
  actionTaken   String?
  tenantId      String
  tenant        Tenant          @relation(fields: [tenantId], references: [id])
  capturedAt    DateTime        @default(now())

  @@index([tenantId])
  @@index([personId])
  @@index([capturedAt])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId  String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([tenantId])
}
